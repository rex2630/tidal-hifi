{
  "compilerOptions": {
    "typeRoots": ["src/types", "node_modules/@types"],
    "module": "commonjs",
    "target": "ES6",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "noImplicitAny": true,
    "sourceMap": true,
    "allowJs": true,
    "outDir": "ts-dist",
    "rootDir": "src",
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "skipLibCheck": true
  },
  "include": ["src/**/*"]
}
