  "paths": {
    "/image": {
      "get": {
        "summary": "Get current image",
        "tags": [
          "legacy"
        ],
        "deprecated": true,
        "responses": {
          "200": {
            "description": "Current image",
            "content": {
              "image/png": {
                "schema": {
                  "type": "string",
                  "format": "binary"
                }
              }
            }
          },
          "404": {
            "description": "Not found"
          }
        }
      }
    },
    "/play": {
      "get": {
        "summary": "Play the current media",
